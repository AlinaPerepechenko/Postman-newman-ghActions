          "name": "List products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const productSchema = {\r",
                  "    \"type\": \"object\",\r",
                  "    \"required\": [\"id\", \"name\", \"price\", \"sku\", \"description\"],\r",
                  "    \"properties\": {\r",
                  "        \"id\": { \"type\": \"number\" },\r",
                  "        \"name\": { \"type\": \"string\" },\r",
                  "        \"price\": { \"type\": \"number\" },\r",
                  "        \"sku\": { \"type\": \"number\" },\r",
                  "        \"description\": { \"type\": \"string\" }\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "pm.test('ASSERT: status code is 200', function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test('ASSERT: response time is less than 300ms', function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(300);\r",
                  "});\r",
                  "\r",
                  "pm.test('ASSERT: Content-Type is present', function () {\r",
                  "    pm.response.to.have.header('Content-Type');\r",
                  "});\r",
                  "\r",
                  "pm.test('ASSERT: response body is a non-empty array', function () {\r",
                  "    const body = pm.response.json();\r",
                  "    pm.expect(body).to.be.an('array');\r",
                  "    pm.expect(body.length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "pm.test('ASSERT: response schema for products is valid', function () {\r",
                  "    pm.response.to.have.jsonSchema({ type: 'array', items: productSchema });\r",
                  "});"
                ],
